# ============================================================
#  Environment variables for the portfolio.
#  Copy this file to `.env` and fill in real values.
#  `.env` is gitignored and must never be committed.
# ============================================================

# --- EmailJS (contact form) ---
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# --- Supabase (Settings -> API in your Supabase dashboard) ---
# Project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=
# anon public key (safe to expose in the frontend)
VITE_SUPABASE_ANON_KEY=

# --- Migration only (NOT used by the frontend) ---
# service_role secret key. Only needed to run scripts/migrate.mjs once.
# Never expose this in client code or commit it.
SUPABASE_SERVICE_ROLE_KEY=
